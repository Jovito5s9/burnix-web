# Desenvolvimento local. Em produção, API_URL e APP_ORIGIN são obrigatórias.

# URL privada usada somente pelo servidor Next.js/BFF para chamar o FastAPI.
# Em Docker Compose, use o hostname interno do serviço.
API_URL=http://localhost:3000

# Origem pública canônica usada para validar mutações no BFF.
APP_ORIGIN=http://localhost:3001

# Limites de corpo do BFF, alinhados aos padrões documentados pelo backend.
BFF_AUTH_REQUEST_MAX_BODY_BYTES=16384
BFF_REGISTRATION_REQUEST_MAX_BODY_BYTES=262144
BFF_FORM_FIELD_REQUEST_MAX_BODY_BYTES=65536
BFF_REQUEST_BODY_DEFAULT_MAX_BYTES=1048576
