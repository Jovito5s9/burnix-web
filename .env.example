# URL privada usada pelo servidor Next.js/BFF para chamar o backend FastAPI.
# Em Docker, pode ser o hostname interno do serviço:
# API_URL=http://backend:8000
API_URL=http://localhost:8000

# Origem pública canônica opcional para validação de mutações no BFF.
# APP_ORIGIN=https://app.seudominio.com

# Compatibilidade temporária com instalações anteriores. Prefira API_URL.
# NEXT_PUBLIC_API_URL=http://localhost:8000
